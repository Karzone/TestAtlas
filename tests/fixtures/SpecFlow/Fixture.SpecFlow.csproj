<Project Sdk="Microsoft.NET.Sdk">

  <!-- Fixture input for TestAtlas tests. NOT part of TestAtlas.sln; loaded by the indexer at
       test time. SpecFlow attributes are local shims (real TechTalk.SpecFlow namespace) so the
       fixture needs no packages and stays offline + deterministic. -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>Fixture.SpecFlow</RootNamespace>
    <AssemblyName>Fixture.SpecFlow</AssemblyName>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Features\**\*.feature" />
  </ItemGroup>

  <!-- A real ProjectReference: the SpecFlow features bind a step defined in the Reqnroll project. It
       exercises the map's `references` edge (build/DI dependency the semantic edges would otherwise
       already cover here). -->
  <ItemGroup>
    <ProjectReference Include="..\Reqnroll\Fixture.Reqnroll.csproj" />
  </ItemGroup>

</Project>
